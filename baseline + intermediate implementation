    "# 1. System Cleanup & Dependency Installation\n",
    "import os\n",
    "import time\n",
    "import subprocess\n",
    "\n",
    "# Force kill any lingering Ray processes and clear corrupted session files\n",
    "try:\n",
    "    subprocess.run([\"ray\", \"stop\", \"--force\"], check=False, capture_output=True)\n",
    "    time.sleep(2)\n",
    "except Exception:\n",
    "    pass\n",
    "os.system(\"rm -rf /tmp/ray/*\")\n",
    "\n",
    "# Install strict dependency versions\n",
    "!pip uninstall -y protobuf\n",
    "!pip install -q \"protobuf<5.0.0\" \"flwr[simulation]>=1.8.0\" torchvision scikit-learn\n",
    "\n",
    "# 2. Imports\n",
    "import torch\n",
    "import torch.nn as nn\n",
    "import torch.nn.functional as F\n",
    "import numpy as np\n",
    "import flwr as fl\n",
    "from typing import Dict, List, Tuple\n",
    "from flwr.common import ndarrays_to_parameters, parameters_to_ndarrays\n",
    "from torch.utils.data import DataLoader, Subset\n",
    "from torchvision import datasets, transforms\n",
    "\n",
    "# Suppress background telemetry noise\n",
    "os.environ['TF_CPP_MIN_LOG_LEVEL'] = '3'\n",
    "os.environ['RAY_DEDUP_LOGS'] = '0'\n",
    "\n",
    "# 3. Device & Configuration\n",
    "NUM_GPUS = torch.cuda.device_count()\n",
    "DEVICE = torch.device('cuda:0' if NUM_GPUS > 0 else 'cpu')\n",
    "\n",
    "class Config:\n",
    "    DATA_DIR = '/kaggle/working/data'\n",
    "    CHECKPOINT_DIR = '/kaggle/working/checkpoints'\n",
    "    NUM_CLIENTS = 10\n",
    "    IID = False            \n",
    "    BATCH_SIZE = 128\n",
    "    LOCAL_EPOCHS = 2\n",
    "    LEARNING_RATE = 1e-3\n",
    "    NUM_ROUNDS = 10\n",
    "    \n",
    "    # Trust & Privacy Hyperparameters\n",
    "    LAMBDA = 0.8           \n",
    "    K_NOISE = 0.05         \n",
    "    EPSILON = 1e-3         \n",
    "\n",
    "CFG = Config()\n",
    "os.makedirs(CFG.CHECKPOINT_DIR, exist_ok=True)\n",
    "\n",
    "# 4. Model Architecture\n",
    "class MnistCNN(nn.Module):\n",
    "    def __init__(self) -> None:\n",
    "        super().__init__()\n",
    "        self.conv1 = nn.Conv2d(1, 32, 3, padding=1); self.bn1 = nn.BatchNorm2d(32)\n",
    "        self.conv2 = nn.Conv2d(32, 64, 3, padding=1); self.bn2 = nn.BatchNorm2d(64)\n",
    "        self.pool = nn.MaxPool2d(2, 2)\n",
    "        self.fc1 = nn.Linear(64 * 7 * 7, 128)\n",
    "        self.dropout = nn.Dropout(0.25)\n",
    "        self.fc2 = nn.Linear(128, 10)\n",
    "\n",
    "    def forward(self, x: torch.Tensor) -> torch.Tensor:\n",
    "        x = self.pool(F.relu(self.bn1(self.conv1(x))))\n",
    "        x = self.pool(F.relu(self.bn2(self.conv2(x))))\n",
    "        x = torch.flatten(x, 1)\n",
    "        x = F.relu(self.fc1(x))\n",
    "        x = self.dropout(x)\n",
    "        return self.fc2(x)\n",
    "\n",
    "# 5. Trust-Adaptive Strategy\n",
    "class TrustAdaptiveStrategy(fl.server.strategy.FedAvg):\n",
    "    def __init__(self, **kwargs):\n",
    "        super().__init__(**kwargs)\n",
    "        self.trust_scores = {str(i): 0.5 for i in range(CFG.NUM_CLIENTS)}\n",
    "\n",
    "    def aggregate_fit(self, server_round, results, failures):\n",
    "        if not results: return None, {}\n",
    "\n",
    "        weighted_results = []\n",
    "        total_trust = 0.0\n",
    "\n",
    "        print(f\"\\n--- Round {server_round} Trust & Privacy Report ---\")\n",
    "        \n",
    "        for client_proxy, fit_res in results:\n",
    "            # cid is now strictly \"0\" through \"9\"\n",
    "            cid = str(client_proxy.cid) \n",
    "            \n",
    "            # Trust Score Calculation\n",
    "            p_i = fit_res.metrics.get(\"accuracy\", 0.0)\n",
    "            t_old = self.trust_scores.get(cid, 0.5)\n",
    "            t_new = max(0.0, min(1.0, CFG.LAMBDA * t_old + (1.0 - CFG.LAMBDA) * p_i))\n",
    "            self.trust_scores[cid] = t_new\n",
    "\n",
    "            # Adaptive Privacy (Noise Injection)\n",
    "            sigma_sq = CFG.K_NOISE / (t_new + CFG.EPSILON)\n",
    "            sigma = np.sqrt(sigma_sq)\n",
    "            \n",
    "            params = parameters_to_ndarrays(fit_res.parameters)\n",
    "            noisy_params = [layer + np.random.normal(0, sigma, layer.shape) for layer in params]\n",
    "            \n",
    "            weighted_results.append((noisy_params, t_new))\n",
    "            total_trust += t_new\n",
    "            print(f\"Client {cid:2}: Trust={t_new:.4f} | Noise Sigma={sigma:.4f} | Local Acc={p_i:.4f}\")\n",
    "\n",
    "        # Layer-by-layer Weighted Aggregation\n",
    "        num_layers = len(weighted_results[0][0])\n",
    "        aggregated_params = []\n",
    "        for i in range(num_layers):\n",
    "            layer_sum = np.sum([res[0][i] * res[1] for res in weighted_results], axis=0)\n",
    "            aggregated_params.append(layer_sum / total_trust)\n",
    "            \n",
    "        return ndarrays_to_parameters(aggregated_params), {}\n",
    "\n",
    "# 6. Flower Client\n",
    "class FlowerClient(fl.client.NumPyClient):\n",
    "    def __init__(self, trainloader, valloader):\n",
    "        self.model = MnistCNN().to(DEVICE)\n",
    "        self.trainloader = trainloader\n",
    "        self.valloader = valloader\n",
    "\n",
    "    def fit(self, parameters, config):\n",
    "        params_dict = zip(self.model.state_dict().keys(), parameters)\n",
    "        self.model.load_state_dict({k: torch.tensor(v) for k, v in params_dict}, strict=True)\n",
    "        \n",
    "        optimizer = torch.optim.Adam(self.model.parameters(), lr=CFG.LEARNING_RATE)\n",
    "        self.model.train()\n",
    "        for _ in range(CFG.LOCAL_EPOCHS):\n",
    "            for images, labels in self.trainloader:\n",
    "                images, labels = images.to(DEVICE), labels.to(DEVICE)\n",
    "                optimizer.zero_grad()\n",
    "                F.cross_entropy(self.model(images), labels).backward()\n",
    "                optimizer.step()\n",
    "        \n",
    "        loss, acc_fraction = self.evaluate_local()\n",
    "        return self.get_parameters(config={}), len(self.trainloader.dataset), {\"accuracy\": float(acc_fraction)}\n",
    "\n",
    "    def evaluate_local(self):\n",
    "        self.model.eval()\n",
    "        correct, total = 0, 0\n",
    "        with torch.no_grad():\n",
    "            for images, labels in self.valloader:\n",
    "                images, labels = images.to(DEVICE), labels.to(DEVICE)\n",
    "                outputs = self.model(images)\n",
    "                correct += (outputs.argmax(1) == labels).sum().item()\n",
    "                total += labels.size(0)\n",
    "        return 0.0, correct / total\n",
    "\n",
    "    def get_parameters(self, config):\n",
    "        return [val.cpu().numpy() for _, val in self.model.state_dict().items()]\n",
    "\n",
    "# 7. Data Partitioning\n",
    "def load_data():\n",
    "    transform = transforms.Compose([transforms.ToTensor(), transforms.Normalize((0.1307,), (0.3081,))])\n",
    "    trainset = datasets.MNIST(CFG.DATA_DIR, train=True, download=True, transform=transform)\n",
    "    indices = np.argsort(trainset.targets)\n",
    "    shards = np.array_split(indices, CFG.NUM_CLIENTS)\n",
    "    \n",
    "    train_loaders, val_loaders = [], []\n",
    "    for shard in shards:\n",
    "        split = int(len(shard) * 0.9)\n",
    "        train_loaders.append(DataLoader(Subset(trainset, shard[:split]), batch_size=CFG.BATCH_SIZE, shuffle=True))\n",
    "        val_loaders.append(DataLoader(Subset(trainset, shard[split:]), batch_size=CFG.BATCH_SIZE))\n",
    "        \n",
    "    return train_loaders, val_loaders\n",
    "\n",
    "# 8. Execution\n",
    "if __name__ == \"__main__\":\n",
    "    print(\"Preparing Datasets...\")\n",
