    "# 1. Install Dependencies\n",
    "!pip install -q \"flwr[simulation]>=1.8.0\" torchvision scikit-learn\n",
    "\n",
    "# 2. Imports\n",
    "import os\n",
    "import time\n",
    "import shutil\n",
    "import json\n",
    "import torch\n",
    "import torch.nn as nn\n",
    "import torch.nn.functional as F\n",
    "import numpy as np\n",
    "from pathlib import Path\n",
    "from typing import Tuple, List, Dict, Optional\n",
    "from torch.utils.data import DataLoader, Subset\n",
    "from torchvision import datasets, transforms\n",
    "from sklearn.metrics import f1_score\n",
    "\n",
    "# 3. Device & Configuration\n",
    "NUM_GPUS = torch.cuda.device_count()\n",
    "DEVICE = torch.device('cuda:0' if NUM_GPUS > 0 else 'cpu')\n",
    "USE_MULTI_GPU = NUM_GPUS > 1\n",
    "\n",
    "class Config:\n",
    "    DATA_DIR        = '/kaggle/working/data'\n",
    "    CHECKPOINT_DIR  = '/kaggle/working/checkpoints'\n",
    "    BEST_MODEL_PATH = '/kaggle/working/best_model.pt'\n",
    "    METRICS_LOG     = '/kaggle/working/metrics_log.json'\n",
    "    NUM_CLIENTS     = 10\n",
    "    # Set IID to True for Step 1 to verify the model can actually learn all digits\n",
    "    IID             = True \n",
    "    VAL_RATIO       = 0.1\n",
    "    BATCH_SIZE      = 256  # Increased to utilize dual T4 VRAM\n",
    "    LOCAL_EPOCHS    = 1    # Reduced to prevent local over-fitting/drift\n",
    "    LEARNING_RATE   = 1e-3 # Lowered for stability\n",
    "    NUM_ROUNDS      = 20\n",
    "\n",
    "CFG = Config()\n",
    "os.makedirs(CFG.DATA_DIR, exist_ok=True)\n",
    "os.makedirs(CFG.CHECKPOINT_DIR, exist_ok=True)\n",
    "\n",
    "# 4. Improved Model Architecture (Added Batch Normalization)\n",
    "class MnistCNN(nn.Module):\n",
    "    def __init__(self) -> None:\n",
    "        super().__init__()\n",
    "        self.conv1 = nn.Conv2d(1, 32, 3, padding=1)\n",
    "        self.bn1   = nn.BatchNorm2d(32)\n",
    "        self.conv2 = nn.Conv2d(32, 64, 3, padding=1)\n",
    "        self.bn2   = nn.BatchNorm2d(64)\n",
    "        self.pool  = nn.MaxPool2d(2, 2)\n",
    "        self.fc1   = nn.Linear(64 * 7 * 7, 128)\n",
    "        self.dropout = nn.Dropout(0.25)\n",
    "        self.fc2   = nn.Linear(128, 10)\n",
    "\n",
    "    def forward(self, x: torch.Tensor) -> torch.Tensor:\n",
    "        x = self.pool(F.relu(self.bn1(self.conv1(x))))\n",
    "        x = self.pool(F.relu(self.bn2(self.conv2(x))))\n",
    "        x = torch.flatten(x, 1)\n",
    "        x = F.relu(self.fc1(x))\n",
    "        x = self.dropout(x)\n",
    "        return self.fc2(x)\n",
    "\n",
    "def build_model() -> nn.Module:\n",
    "    model = MnistCNN().to(DEVICE)\n",
    "    if USE_MULTI_GPU:\n",
    "        model = nn.DataParallel(model)\n",
    "    return model\n",
    "\n",
    "# 5. Data Partitioning\n",
    "def get_loaders():\n",
    "    transform = transforms.Compose([\n",
    "        transforms.ToTensor(), \n",
    "        transforms.Normalize((0.1307,), (0.3081,))\n",
    "    ])\n",
    "    train_set = datasets.MNIST(CFG.DATA_DIR, train=True, download=True, transform=transform)\n",
    "    test_set  = datasets.MNIST(CFG.DATA_DIR, train=False, download=True, transform=transform)\n",
    "    \n",
    "    if CFG.IID:\n",
    "        indices = np.random.permutation(len(train_set))\n",
    "    else:\n",
    "        indices = np.argsort(np.array(train_set.targets))\n",
    "        \n",
    "    shards = np.array_split(indices, CFG.NUM_CLIENTS)\n",
    "    train_loaders = [DataLoader(Subset(train_set, s), batch_size=CFG.BATCH_SIZE, shuffle=True, pin_memory=True) for s in shards]\n",
    "    test_loader = DataLoader(test_set, batch_size=CFG.BATCH_SIZE, shuffle=False, pin_memory=True)\n",
    "    return train_loaders, test_loader\n",
    "\n",
    "# 6. Checkpoint Manager\n",
    "class CheckpointManager:\n",
    "    def __init__(self):\n",
    "        self.best_loss = float('inf')\n",
    "        self.metrics_log = Path(CFG.METRICS_LOG)\n",
    "        self.history = []\n",
    "\n",
    "    def save(self, model: nn.Module, epoch: int, loss: float, acc: float, f1: float):\n",
    "        state_dict = model.module.state_dict() if hasattr(model, 'module') else model.state_dict()\n",
    "        filename = f\"epoch{epoch}_loss{loss:.4f}_acc{acc:.4f}.pt\"\n",
    "        path = os.path.join(CFG.CHECKPOINT_DIR, filename)\n",
    "        \n",
    "        payload = {'state_dict': state_dict, 'epoch': epoch, 'loss': loss, 'accuracy': acc, 'f1': f1}\n",
    "        torch.save(payload, path)\n",
    "        \n",
    "        # Save based on BEST LOSS for better generalization\n",
    "        if loss < self.best_loss:\n",
    "            self.best_loss = loss\n",
    "            shutil.copy(path, CFG.BEST_MODEL_PATH)\n",
    "            print(f\"[Checkpoint] New best model (Loss: {loss:.4f})\")\n",
    "\n",
    "        self.history.append(payload)\n",
    "        with open(self.metrics_log, 'w') as f:\n",
    "            json.dump(self.history, f, indent=2, default=str)\n",
    "\n",
    "# 7. Training & Evaluation\n",
    "def train_round(model, loaders, optimizer, criterion):\n",
    "    model.train()\n",
    "    total_loss = 0\n",
    "    # Simulate all clients contributing to the global model\n",
    "    for loader in loaders:\n",
    "        for images, labels in loader:\n",
    "            images, labels = images.to(DEVICE), labels.to(DEVICE)\n",
    "            optimizer.zero_grad()\n",
    "            output = model(images)\n",
    "            loss = criterion(output, labels)\n",
    "            loss.backward()\n",
    "            optimizer.step()\n",
    "            total_loss += loss.item()\n",
    "    return total_loss / (len(loaders) * len(loaders[0]))\n",
    "\n",
    "def evaluate_model(model, loader):\n",
    "    model.eval()\n",
    "    all_preds, all_labels, total_loss = [], [], 0.0\n",
    "    criterion = nn.CrossEntropyLoss()\n",
    "    with torch.no_grad():\n",
    "        for images, labels in loader:\n",
    "            images, labels = images.to(DEVICE), labels.to(DEVICE)\n",
    "            output = model(images)\n",
    "            total_loss += criterion(output, labels).item()\n",
    "            all_preds.extend(output.argmax(dim=1).cpu().numpy())\n",
    "            all_labels.extend(labels.cpu().numpy())\n",
    "    acc = np.mean(np.array(all_preds) == np.array(all_labels))\n",
    "    f1 = f1_score(all_labels, all_preds, average='macro')\n",
    "    return total_loss / len(loader), acc, f1\n",
    "\n",
    "# 8. Execution\n",
    "if __name__ == \"__main__\":\n",
    "    train_loaders, test_loader = get_loaders()\n",
    "    global_model = build_model()\n",
    "    ckpt_manager = CheckpointManager()\n",
    "    # Switched to Adam for better convergence on T4 x2\n",
    "    optimizer = torch.optim.Adam(global_model.parameters(), lr=CFG.LEARNING_RATE)\n",
    "    criterion = nn.CrossEntropyLoss()\n",
    "\n",
    "    print(f\"Starting Optimized Step 1 | Multi-GPU: {USE_MULTI_GPU}\")\n",
    "    for round_idx in range(1, CFG.NUM_ROUNDS + 1):\n",
    "        train_loss = train_round(global_model, train_loaders, optimizer, criterion)\n",
    "        t_loss, t_acc, t_f1 = evaluate_model(global_model, test_loader)\n",
    "        print(f\"R{round_idx} | Train Loss: {train_loss:.4f} | Test Loss: {t_loss:.4f} | Acc: {t_acc:.4f}\")\n",
    "        ckpt_manager.save(global_model, round_idx, t_loss, t_acc, t_f1)"
   ]
